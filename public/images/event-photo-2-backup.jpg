					<item>
		<title><![CDATA[]]></title>
		<link>https://impactauctions.org/?p=5600</link>
		<pubDate></pubDate>
		<dc:creator><![CDATA[liveimpactauctions]]></dc:creator>
		<guid isPermaLink="false">https://impactauctions.org/?p=5600</guid>
		<description></description>
